.orgName { font-size: 14px; color: var(--text-secondary); font-weight: 600; margin-bottom: 12px; }
.eventMeta { color: var(--text-secondary); font-size: 14px; margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }

.recurringPill {
  margin-top: 12px; 
  background-color: var(--bg-main); 
  color: var(--text-secondary);
  padding: 6px 12px; 
  border-radius: 6px; 
  font-size: 13px; 
  border: 1px solid var(--border-light);
}

/* Capacity Styling */
.capacityAvailable { color: #10b981; font-weight: bold; font-size: 13px; }
.capacityFull { color: #ef4444; font-weight: bold; font-size: 13px; }

.emptyState { 
  text-align: center; 
  padding: 60px 20px; 
  background-color: var(--bg-card); 
  border-radius: 12px; 
  border: 1px dashed var(--border-light); 
  color: var(--text-secondary); 
  grid-column: 1 / -1; 
}
.emptyState h2 { color: var(--text-primary); margin-top: 0; }

/* Modal Styles */
.modalOverlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: var(--modal-overlay); display: flex; justify-content: center; align-items: center; z-index: 1000; backdrop-filter: blur(4px); padding: 1rem; }
.modalContent { background-color: var(--bg-card); border-radius: 12px; width: 100%; max-width: 600px; max-height: 90vh; display: flex; flex-direction: column; overflow: hidden; box-shadow: var(--card-shadow); border: 1px solid var(--border-light); }
.modalHeader { padding: 24px; border-bottom: 1px solid var(--border-light); display: flex; justify-content: space-between; align-items: center; background-color: var(--bg-main); }
.modalTitleText { margin: 0; color: var(--text-primary-brand); font-size: 22px; }
.closeBtn { background: none; border: none; font-size: 24px; cursor: pointer; color: var(--text-secondary); transition: color 0.2s; }
