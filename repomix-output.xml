  font-weight: 700;
}

.subtitle {
  color: var(--text-secondary);
  font-size: 16px;
}

/* Modern Tab Navigation */
.tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 24px;
  border-bottom: 2px solid var(--border-light);
  padding-bottom: 16px;
}

.tab {
  padding: 8px 20px;
  border-radius: 20px;
  border: 1px solid transparent;
  background: transparent;
  color: var(--text-secondary);
  cursor: pointer;
  font-weight: 600;
  transition: all 0.2s ease;
  font-size: 14px;
}

.tab:hover {
  background-color: var(--bg-card);
  border-color: var(--border-light);
  color: var(--text-primary);
}

.activeTab {
  background-color: var(--text-primary-brand);
  color: var(--bg-main);
}

.activeTab:hover {
  background-color: var(--text-primary-brand);
  color: var(--bg-main);
  opacity: 0.9;
}

/* Submission List */
.submissionCard {
  background-color: var(--bg-card);
  border-radius: 12px;
  padding: 24px;
  margin-bottom: 16px;
  box-shadow: var(--card-shadow);
  border: 1px solid var(--border-light);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  transition: transform 0.2s, border-color 0.2s;
  flex-wrap: wrap;
  gap: 20px;
}

.submissionCard:hover {
  border-color: var(--text-primary-brand);
}

.details {
  flex: 1;
  min-width: 250px;
}

.eventTitle {
  margin: 0 0 12px 0;
  color: var(--text-primary);
  font-size: 20px;
}

.metaData {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
  color: var(--text-secondary);
  font-size: 14px;
  margin-bottom: 16px;
}

.totalCredit {
  font-weight: bold;
  color: var(--text-primary-brand);
}

.selectedDaysBadge {
  background-color: var(--bg-main);
  color: var(--text-secondary);
  padding: 6px 10px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 600;
  display: inline-block;
  margin-top: 8px;
  border: 1px solid var(--border-light);
}

/* Feedback Box Logic */
.feedbackBox {
  margin-top: 16px;
  padding: 12px;
  font-size: 14px;
  border-radius: 0 8px 8px 0;
}

.feedbackApproved {
