}
.successTitle { color: #10b981; margin-top: 0; margin-bottom: 16px; font-size: 20px; }
.successLabel { color: var(--text-secondary); }
.successText { color: var(--text-primary); font-weight: 500; margin-left: 8px; }

.creditText { margin-top: 16px; padding-top: 16px; border-top: 1px dashed rgba(16, 185, 129, 0.2); }
.creditHighlight { color: #10b981; font-size: 18px; font-weight: 800; margin-left: 8px; }

/* Registration Box */
.daySelectionBox {
  background-color: var(--bg-main);
  padding: 20px;
  border-radius: 8px;
  border: 1px solid var(--border-light);
  margin-bottom: 24px;
}
.daySelectionTitle { display: block; margin-bottom: 8px; color: var(--text-primary); font-size: 16px; }
.daySelectionSubtitle { font-size: 13px; color: var(--text-secondary); margin-top: 0; margin-bottom: 16px; }

.daySelector { display: flex; gap: 8px; flex-wrap: wrap; }
.dayBtn { padding: 10px 16px; border: 1px solid var(--border-light); border-radius: 20px; background-color: var(--bg-card); cursor: pointer; font-size: 14px; font-weight: 600; color: var(--text-secondary); transition: all 0.2s; }
.dayBtn:hover { border-color: var(--text-primary-brand); color: var(--text-primary-brand); }
.dayActive { background-color: var(--text-primary-brand); color: var(--bg-main); border-color: var(--text-primary-brand); }
.dayActive:hover { opacity: 0.9; }

.projectedCreditBox {
  text-align: center;
  padding: 16px;
  background-color: var(--bg-main);
  border-radius: 8px;
  border: 1px solid var(--border-light);
}
.projectedLabel { color: var(--text-secondary); font-size: 15px; }
.projectedCreditHighlight { color: var(--text-primary-brand); font-size: 24px; font-weight: 800; display: block; margin-top: 4px; }

/* Actions */
.modalActions { padding: 20px 24px; border-top: 1px solid var(--border-light); display: flex; justify-content: space-between; align-items: center; background-color: var(--bg-main); flex-wrap: wrap; gap: 12px; }
.actionGroupRight { display: flex; gap: 12px; margin-left: auto; }

.cancelBtn { background-color: transparent; border: 1px solid var(--border-light); color: var(--text-primary); padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: 600; transition: 0.2s; }
.cancelBtn:hover { background-color: var(--bg-card); }

.submitBtn { background-color: var(--text-primary-brand); color: var(--bg-main); border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: 600; transition: 0.2s; }
.submitBtn:disabled { opacity: 0.5; cursor: not-allowed; }

.unregisterBtnModal { background-color: transparent; color: #ef4444; border: 1px solid #ef4444; padding: 10px 20px; border-radius: 6px; font-weight: bold; cursor: pointer; transition: 0.2s; }
.unregisterBtnModal:hover:not(:disabled) { background-color: rgba(239, 68, 68, 0.1); }

/* --- PAGINATION --- */
.paginationContainer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 24px;
  background-color: var(--bg-main);
  border: 1px solid var(--border-light);
  border-radius: 12px;
  margin-top: 24px;
}

.pageInfo {
  font-size: 14px;
  color: var(--text-secondary);
  font-weight: 500;
}

.paginationControls {
  display: flex;
  gap: 12px;
}

.pageBtn {
  padding: 8px 16px;
  background-color: var(--bg-card);
  border: 1px solid var(--border-light);
  color: var(--text-primary);
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}

.pageBtn:hover:not(:disabled) {
  background-color: var(--bg-main);
  border-color: var(--text-primary-brand);
  color: var(--text-primary-brand);
  transform: translateY(-1px);
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
}

.pageBtn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
  background-color: var(--bg-main);
  box-shadow: none;
}

/* --- MOBILE RESPONSIVENESS (Max Width 768px) --- */
@media (max-width: 768px) {
  /* 1. Reclaim screen real estate */
  .container {
    padding: 16px;
  }

  /* 2. Stack the Header and Search Bar */
  .header {
    flex-direction: column;
    gap: 16px;
    margin-bottom: 24px;
  }

  .headerText {
    min-width: 100%;
  }

  .title {
    font-size: 24px;
  }

  /* Make Search Bar span 100% of the screen */
  .searchBox {
    max-width: 100%;
    min-width: 100%;
    width: 100%;
  }

  /* 3. The Grid Collapse: Force 1 column on tiny phones */
  .eventsGrid {
    grid-template-columns: 1fr; /* Overrides the 320px minmax for safety */
    gap: 16px;
  }

  .eventCard {
    padding: 16px;
  }

  .eventTitle {
    font-size: 18px;
  }

  /* 4. Modal Squeeze: Shrink padding to fit small screens */
  .modalHeader, .modalBody {
    padding: 16px;
  }

  .modalTitleText {
    font-size: 20px;
  }

  /* 5. Day Selector Pills */
  .dayBtn {
    flex: 1 1 calc(33% - 8px); /* Make buttons evenly fill the row */
    text-align: center;
    padding: 12px 8px; /* Taller for thumbs */
  }

  /* 6. Giant Thumb Targets for Action Buttons */
  .modalActions {
    padding: 16px;
    flex-direction: column;
    gap: 12px;
  }

  .actionGroupRight {
    width: 100%;
    flex-direction: column-reverse; /* Primary action on top */
    gap: 12px;
    margin-left: 0;
  }

  .submitBtn, .cancelBtn, .unregisterBtnModal {
    width: 100%;
    text-align: center;
    padding: 12px;
  }
}
