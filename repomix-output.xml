/* src/app/(dashboards)/student/events/page.module.css */

.container { padding-bottom: 40px; }

.loadingState {
  padding: 40px;
  text-align: center;
  color: var(--text-secondary);
  font-size: 1.1rem;
}

.header { 
  display: flex; 
  justify-content: space-between; 
  align-items: flex-start; 
  margin-bottom: 30px; 
  flex-wrap: wrap; 
  gap: 20px; 
}

.headerText { flex: 1; min-width: 300px; }
.title { font-size: 28px; color: var(--text-primary-brand); margin-bottom: 8px; font-weight: 700; margin-top: 0; }
.subtitle { color: var(--text-secondary); font-size: 16px; margin: 0; }

/* Search Box Styling */
.searchBox {
  display: flex;
  align-items: center;
  background-color: var(--bg-card);
  border: 1px solid var(--border-light);
  border-radius: 8px;
  padding: 8px 16px;
  flex: 1;
  max-width: 400px;
  min-width: 250px;
  box-shadow: var(--card-shadow);
  transition: border-color 0.2s;
}

.searchBox:focus-within {
